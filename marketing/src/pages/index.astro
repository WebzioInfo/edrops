---
import BaseLayout from '../layouts/BaseLayout.astro';
import MarketingWaterJar from '../components/MarketingWaterJar';

const features = [
  ['Balance intelligence', 'A live prepaid jar balance that customers understand instantly.'],
  ['Subscription rhythm', 'Recurring deliveries, pause windows, recharge timing, and consumption forecasting.'],
  ['Operations clarity', 'Routes, staff workload, low-balance risk, and delivery exceptions in one calm view.'],
];

const steps = [
  ['Recharge', 'Customers buy jar packs in advance.'],
  ['Deliver', 'Each completed delivery consumes balance.'],
  ['Predict', 'Edrops forecasts recharge need before water runs low.'],
];
---

<BaseLayout
  title="Edrops Water Subscription Platform"
  description="A premium prepaid water delivery platform for 20L jar subscriptions, balance intelligence, and delivery operations."
>
  <nav class="fixed inset-x-0 top-0 z-50 border-b border-white/60 bg-white/72 backdrop-blur-2xl">
    <div class="mx-auto flex h-20 max-w-7xl items-center justify-between px-5">
      <a href="/" class="flex items-center gap-3">
        <span class="flex h-11 w-11 items-center justify-center rounded-2xl water-gradient text-white shadow-lg shadow-edrops-aqua/20">E</span>
        <span class="text-xl font-black tracking-tight text-edrops-ocean">Edrops</span>
      </a>
      <div class="hidden items-center gap-8 text-sm font-black text-edrops-ocean/62 md:flex">
        <a href="/features">Features</a>
        <a href="/pricing">Pricing</a>
        <a href="/how-it-works">How it works</a>
        <a href="/about">About</a>
      </div>
      <a href="http://localhost:5173/login" class="rounded-full sun-gradient px-5 py-3 text-sm font-black text-white shadow-lg shadow-orange-300/40">Open app</a>
    </div>
  </nav>

  <main class="overflow-hidden pt-20 text-edrops-ocean">
    <section class="relative min-h-[calc(100vh-5rem)] px-5 py-14">
      <div class="pointer-events-none absolute inset-0">
        <div class="absolute left-[-12rem] top-[-12rem] h-[34rem] w-[34rem] rounded-full bg-edrops-light/52 blur-3xl"></div>
        <div class="absolute right-[-8rem] top-16 h-[26rem] w-[26rem] rounded-full bg-edrops-aqua/20 blur-3xl"></div>
      </div>
      <div class="relative mx-auto grid max-w-7xl gap-10 lg:grid-cols-[1fr_30rem] lg:items-center">
        <div>
          <p class="inline-flex rounded-full bg-white/74 px-4 py-2 text-xs font-black uppercase tracking-[0.24em] text-edrops-primary shadow-sm">Premium water subscription SaaS</p>
          <h1 class="mt-7 max-w-4xl text-5xl font-black tracking-tight sm:text-7xl">Water delivery that feels intelligent, calm, and premium.</h1>
          <p class="mt-6 max-w-2xl text-lg font-medium leading-9 text-edrops-ocean/68">
            Edrops is built for 20L water jar businesses where prepaid balance, recurring delivery, customer trust, and operations all flow together.
          </p>
          <div class="mt-9 flex flex-col gap-3 sm:flex-row">
            <a href="http://localhost:5173/customer" class="rounded-full sun-gradient px-7 py-4 text-center text-sm font-black text-white shadow-xl shadow-orange-300/40">Explore customer portal</a>
            <a href="/features" class="rounded-full bg-white/78 px-7 py-4 text-center text-sm font-black text-edrops-ocean shadow-sm">See platform</a>
          </div>
        </div>

        <div class="water-shell relative min-h-[36rem] overflow-hidden rounded-[2.75rem] p-4 sm:p-7">
          <div class="absolute inset-x-0 bottom-0 h-40 wave-mask"></div>
          <MarketingWaterJar client:load balance={20} total={30} />
          <div class="relative -mt-10 grid gap-3 sm:grid-cols-2">
            <div class="rounded-[1.5rem] bg-white/68 p-5">
              <p class="text-xs font-black uppercase tracking-[0.22em] text-edrops-primary">Live balance</p>
              <p class="mt-2 text-4xl font-black">20 jars</p>
            </div>
            <div class="rounded-[1.5rem] ocean-gradient p-5 text-white">
              <p class="text-xs font-black uppercase tracking-[0.22em] text-white/68">Next delivery</p>
              <p class="mt-2 text-2xl font-black">Tomorrow, 9 AM</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="px-5 py-20">
      <div class="mx-auto max-w-7xl">
        <div class="max-w-2xl">
          <p class="text-xs font-black uppercase tracking-[0.24em] text-edrops-primary">Why Edrops</p>
          <h2 class="mt-4 text-4xl font-black tracking-tight sm:text-6xl">Not ERP. Not delivery clone. Water subscription intelligence.</h2>
        </div>
        <div class="mt-10 grid gap-5 md:grid-cols-3">
          {features.map(([title, text]) => (
            <article class="premium-card p-7">
              <h3 class="text-2xl font-black">{title}</h3>
              <p class="mt-4 text-sm font-semibold leading-7 text-edrops-ocean/62">{text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="px-5 py-20">
      <div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[28rem_1fr] lg:items-center">
        <div class="water-shell rounded-[2.75rem] p-5">
          <MarketingWaterJar client:visible balance={10} total={30} />
        </div>
        <div>
          <p class="text-xs font-black uppercase tracking-[0.24em] text-edrops-primary">Water jar showcase</p>
          <h2 class="mt-4 text-4xl font-black tracking-tight sm:text-6xl">The jar explains the business model.</h2>
          <p class="mt-6 text-lg font-medium leading-9 text-edrops-ocean/68">A customer purchases 30 jars, deliveries consume balance, and recharge fills the jar again. Edrops turns prepaid water delivery into a visual system every customer understands.</p>
        </div>
      </div>
    </section>

    <section class="px-5 py-20">
      <div class="mx-auto max-w-7xl rounded-[3rem] bg-edrops-ocean p-7 text-white sm:p-10">
        <p class="text-xs font-black uppercase tracking-[0.24em] text-edrops-light">How it works</p>
        <div class="mt-8 grid gap-5 md:grid-cols-3">
          {steps.map(([title, text], index) => (
            <article class="rounded-[2rem] bg-white/10 p-7">
              <p class="text-sm font-black text-edrops-sky">0{index + 1}</p>
              <h3 class="mt-4 text-3xl font-black">{title}</h3>
              <p class="mt-4 text-sm font-semibold leading-7 text-white/68">{text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
