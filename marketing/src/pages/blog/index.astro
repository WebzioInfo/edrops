---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
const posts = await getCollection('blog');
---
<BaseLayout title="Water Delivery Business Blog | Edrops" description="SEO guides for water delivery operations, subscription management, customer retention, and delivery optimization.">
  <main class="mx-auto max-w-6xl px-5 py-20 text-edrops-ocean">
    <a href="/" class="font-black text-edrops-primary">Edrops</a>
    <h1 class="mt-8 text-5xl font-black tracking-tight sm:text-7xl">Water delivery growth insights.</h1>
    <div class="mt-12 grid gap-5 md:grid-cols-2">
      {posts.map((post) => (
        <a href={`/blog/${post.id.replace(/\.md$/, '')}`} class="premium-card block p-7">
          <p class="text-xs font-black uppercase tracking-[0.2em] text-edrops-primary">{post.data.category}</p>
          <h2 class="mt-4 text-2xl font-black">{post.data.title}</h2>
          <p class="mt-4 text-sm font-semibold leading-7 text-edrops-ocean/62">{post.data.description}</p>
        </a>
      ))}
    </div>
  </main>
</BaseLayout>
