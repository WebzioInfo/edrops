---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found | Edrops" description="The requested Edrops page was not found.">
  <main class="flex min-h-screen items-center justify-center px-5 text-edrops-ocean">
    <section class="water-shell max-w-xl rounded-[2.75rem] p-8 text-center">
      <p class="text-sm font-black uppercase tracking-[0.24em] text-edrops-primary">404</p>
      <h1 class="mt-5 text-5xl font-black tracking-tight">This flow dried up.</h1>
      <p class="mt-5 text-sm font-semibold leading-7 text-edrops-ocean/62">Return to the Edrops home page and continue from a live route.</p>
      <a href="/" class="mt-8 inline-flex rounded-full sun-gradient px-7 py-4 text-sm font-black text-white">Go home</a>
    </section>
  </main>
</BaseLayout>
