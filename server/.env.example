# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/edrops?schema=public"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=30d

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
# Comma-separated list of allowed frontend origins in production
CORS_ORIGINS=https://order.edrops.com,https://admin.edrops.com,https://edrops.com

# ─── SMS / OTP ────────────────────────────────────────────────────────────────
# Options: 'fast2sms' | 'msg91' | 'console' (dev default — logs to terminal)
SMS_PROVIDER=console
SMS_API_KEY=your_fast2sms_or_msg91_api_key
# Only needed for MSG91
MSG91_TEMPLATE_ID=your_msg91_template_id

# ─── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_from_razorpay_dashboard
